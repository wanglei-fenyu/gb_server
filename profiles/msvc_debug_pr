[settings]
arch=x86_64
build_type=Debug
compiler=msvc
compiler.cppstd=23
compiler.runtime=dynamic
compiler.version=195
os=Windows

[options]
boost/*:without_cobalt=True
boost/*:without_process=True
protobuf/*:shared=False

[conf]
tools.build:cxxflags+=["/DBOOST_CHARCONV_DISABLE_FLOAT128"]
tools.build:skip_test=True
tools.build:jobs=8

[buildenv]
CC="cl"
CXX="cl"
VS_INSTALL_PATH="C:/Program Files/Microsoft Visual Studio/18/Community"
