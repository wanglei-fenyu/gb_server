[settings]
arch=x86_64
build_type=Release
compiler=clang
compiler.cppstd=gnu23
compiler.libcxx=libstdc++11
compiler.version=22
os=Linux

[options]
boost/*:without_cobalt=True
protobuf/*:shared=False

[conf]
tools.build:cxxflags+=["-DBOOST_CHARCONV_DISABLE_FLOAT128","-Wno-register"]
tools.build:skip_test=True
tools.build:jobs=8
tools.cmake.cmaketoolchain:generator=Ninja

[buildenv]
CC=clang-22
CXX=clang++-22
PATH=$penv{PATH}:/tmp/ninja
